# Copy to `.env` and fill in. `.env` is gitignored — never commit your real key.
# Used for the live eval (scripts/run_eval.py --record) and the live MCP server.
# Load it with:  uv run --env-file .env <command>
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: which model the MCP server uses (default: claude-haiku-4-5)
# BREAK_CLAUSE_MODEL=claude-sonnet-4-6
